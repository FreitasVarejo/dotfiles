{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "snapshot": true,
  "permission": {},
  "tools": {},
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "build/**",
      "coverage/**"
    ]
  },
  "mcp": {
    "docker": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-docker"],
      "enabled": false
    },
    "sqlite": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sqlite", "--db-path", "${workspaceFolder}/cv_pipeline/metadata.db"],
      "enabled": false
    },
    "git": {
      "type": "local",
      "command": ["npx", "-y", "git-mcp"],
      "enabled": true
    }
  }
}
